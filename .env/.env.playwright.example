# Brevo
BREVO_TOKEN=

# Resend
RESEND_KEY=
MAIL_SENDER_ADDRESS=

# PDF generation api token
PDF_GENERATION_SECRET=

# Tracking
NEXT_PUBLIC_TRACKING_SITE_ID=
FATHOM_API_KEY=
NEXT_PUBLIC_TRACKING_DISABLED=